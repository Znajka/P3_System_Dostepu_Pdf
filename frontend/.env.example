# Spring Boot backend
REACT_APP_SPRING_BOOT_URL=http://localhost:8080

# FastAPI microservice
REACT_APP_FASTAPI_URL=https://localhost:8443

# Environment
REACT_APP_ENV=development

# PDF.js configuration
REACT_APP_PDF_WORKER_SRC=https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js
REACT_APP_PDF_MAX_ZOOM=3.0
REACT_APP_PDF_MIN_ZOOM=0.5

# Security
REACT_APP_DISABLE_PRINT=true
REACT_APP_DISABLE_DOWNLOAD=true
REACT_APP_DISABLE_CONTEXT_MENU=true