# PostgreSQL
POSTGRES_DB=p3_system_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=strong-postgres-password

# Spring Boot
SPRING_PROFILES_ACTIVE=docker
APP_JWT_SECRET=your-very-long-jwt-secret-at-least-32-chars
APP_JWT_EXPIRATION_MS=3600000
APP_REFRESH_TOKEN_EXPIRATION_MS=604800000

# KMS (Vault)
KMS_PROVIDER=vault
KMS_ENDPOINT=http://vault:8200
KMS_AUTH_TOKEN=s.your-vault-token
VAULT_ROOT_TOKEN=root-token

# FastAPI
FASTAPI_ENV=docker
FASTAPI_SERVICE_URL=https://fastapi-pdf-service:8443
FASTAPI_LOGGING_LEVEL=INFO
FASTAPI_WORKERS=4
FASTAPI_STREAM_CHUNK_SIZE=65536

# Storage
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=/data/encrypted-documents
MAX_PDF_SIZE=104857600

# Rate Limiting
APP_RATE_LIMIT_ENABLED=true
APP_RATE_LIMIT_FAILED_ATTEMPTS=5
APP_RATE_LIMIT_WINDOW_MINUTES=15
APP_RATE_LIMIT_LOCKOUT_MINUTES=30

# Scheduled Tasks
GRANT_EXPIRATION_ENABLED=true
GRANT_EXPIRATION_INTERVAL_SECONDS=300
GRANT_EXPIRATION_INITIAL_DELAY_SECONDS=60
EXPIRATION_NOTIFICATION_ENABLED=false
EXPIRATION_NOTIFICATION_HOURS_BEFORE=24

# Admin Tools (dev only)
PGADMIN_EMAIL=admin@p3.local
PGADMIN_PASSWORD=admin-password

# Logging
APP_LOGGING_LEVEL=INFO

# Security: IP Pinning
APP_SECURITY_IP_PINNING_ENABLED=true