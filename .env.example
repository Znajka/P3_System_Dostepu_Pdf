# Copy to ".env" in the repo root:  cp .env.example .env  (then edit if needed)
# Docker Compose reads .env automatically.

# Database
POSTGRES_DB=p3_system_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Shared JWT signing secret (Spring + FastAPI). Use a long random string in production.
APP_JWT_SECRET=dev-jwt-secret-change-me-use-32plus-chars

# Service-to-service ticket consumption (Spring internal API)
APP_INTERNAL_API_KEY=dev-p3-internal-api-key

# Optional: disable IP pinning when requests hit Spring vs FastAPI from different client paths
APP_SECURITY_IP_PINNING_ENABLED=false

# Vault dev server token (matches docker-compose vault service)
KMS_AUTH_TOKEN=root-token

# Only needed if you run: docker compose --profile dev up  (pgAdmin)
PGADMIN_EMAIL=admin@p3.local
PGADMIN_PASSWORD=admin
