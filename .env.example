# Copy to .env to override Compose defaults (optional — docker-compose.yml has dev defaults baked in).
POSTGRES_PASSWORD=devpostgres
POSTGRES_DB=p3_system_db
POSTGRES_USER=postgres

APP_JWT_SECRET=dev-jwt-secret-min-32-chars-for-hs256-demo!!
KMS_AUTH_TOKEN=root-token

# Browser → FastAPI streaming (SPA built into Spring Boot JAR reads this URL at build time)
REACT_APP_FASTAPI_URL=http://localhost:8443
